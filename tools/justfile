# だんいんログ — データ管理コマンド

scripts := "scripts"

# ---------- YouTube データ取得 ----------

# 全件取得（白銀ノエルch）
fetch:
    cd {{scripts}} && python3 youtube_data_fetcher.py

# 単一動画取得
fetch-one video_id:
    cd {{scripts}} && python3 youtube_data_fetcher.py {{video_id}}

# チャンネル追加/更新
channel-add +channel_ids:
    cd {{scripts}} && python3 channel_inserter.py {{channel_ids}}

# ---------- タグ分類 ----------

# 新着のみ自動分類 → 中間CSV出力（人手レビュー用）
tags:
    cd {{scripts}} && python3 stream_tag_extractor.py

# 全件再分類 → 中間CSV出力
tags-all:
    cd {{scripts}} && python3 stream_tag_extractor.py --all

# レビュー済み中間CSV → video_stream_tags.csv
tags-import:
    cd {{scripts}} && python3 tags_importer.py

# 全件精度検証（人手タグとの突合レポート）
tags-verify:
    cd {{scripts}} && python3 stream_tag_extractor.py --verify

# ---------- 楽曲抽出（Step 1: 中間CSV出力） ----------

# 歌枠+ライブ両方
songs:
    cd {{scripts}} && python3 extract_songs.py

# 歌枠のみ
songs-stream:
    cd {{scripts}} && python3 extract_songs.py --type stream

# ライブのみ
songs-live:
    cd {{scripts}} && python3 extract_songs.py --type live

# ---------- 楽曲インポート（Step 3: レビュー済み中間CSV → 正規化CSV） ----------

# 歌枠の中間CSV → songs.csv + stream_songs.csv
songs-import-stream:
    cd {{scripts}} && python3 songs_importer.py stream

# ライブの中間CSV → songs.csv + concert_songs.csv
songs-import-live:
    cd {{scripts}} && python3 songs_importer.py live

# ---------- アーティスト補完（Step 4） ----------

# Spotify API で TODO 曲のアーティストを補完
artists:
    cd {{scripts}} && python3 update_song_artists.py

