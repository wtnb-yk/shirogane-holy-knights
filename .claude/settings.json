{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cat | .claude/scripts/check-component.sh",
            "timeout": 10,
            "statusMessage": "コンポーネント設計チェック..."
          }
        ]
      }
    ]
  }
}